{
  "name": "vulnerable-by-design/composer-app",
  "description": "A Composer project with intentionally vulnerable and deprecated dependencies for security testing",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Security Testing",
      "email": "test@example.com",
      "role": "Developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,

  "_comment_require": "DIRECT DEPENDENCIES — vulnerable packages with various version constraint formats",
  "require": {
    "php": ">=5.6.0",

    "_comment_exact": "--- Exact versions ---",
    "phpmailer/phpmailer": "5.2.16",
    "guzzlehttp/guzzle": "6.3.0",
    "symfony/http-foundation": "2.7.0",
    "symfony/http-kernel": "2.7.0",
    "symfony/console": "2.7.0",
    "symfony/yaml": "2.7.0",
    "symfony/security": "2.7.0",
    "symfony/validator": "2.7.0",
    "symfony/serializer": "2.7.0",
    "twig/twig": "1.19.0",
    "monolog/monolog": "1.11.0",
    "aws/aws-sdk-php": "2.8.0",
    "swiftmailer/swiftmailer": "5.2.0",

    "_comment_caret": "--- Caret ranges (^) — allows minor/patch updates ---",
    "laravel/framework": "^5.4.0",
    "league/flysystem": "^1.0.0",
    "doctrine/orm": "^2.5.0",
    "doctrine/dbal": "^2.5.0",
    "vlucas/phpdotenv": "^2.0.0",
    "nesbot/carbon": "^1.20.0",
    "intervention/image": "^2.3.0",
    "barryvdh/laravel-debugbar": "^2.0.0",
    "dompdf/dompdf": "^0.6.0",
    "phpoffice/phpspreadsheet": "^1.0.0",

    "_comment_tilde": "--- Tilde ranges (~) — allows patch updates only ---",
    "nikic/php-parser": "~1.0.0",
    "predis/predis": "~1.0.0",
    "psr/log": "~1.0.0",
    "paragonie/random_compat": "~1.0",
    "phpseclib/phpseclib": "~2.0.0",
    "tecnickcom/tcpdf": "~6.2.0",

    "_comment_wildcard": "--- Wildcard ranges (*) ---",
    "league/oauth2-client": "1.0.*",
    "ezyang/htmlpurifier": "4.6.*",
    "robmorgan/phinx": "0.4.*",
    "fzaninotto/faker": "1.4.*",

    "_comment_range": "--- Explicit ranges and comparisons ---",
    "psr/http-message": ">=1.0.0 <1.1.0",
    "guzzlehttp/psr7": ">=1.0.0 <1.5.0",
    "slim/slim": ">=3.0.0 <3.12.0",

    "_comment_or": "--- OR constraints (||) ---",
    "psr/container": "1.0.0 || 1.1.0",

    "_comment_critical_cves": "--- Packages with known critical CVEs ---",
    "phpunit/phpunit": "4.8.0",
    "league/commonmark": "0.15.0",
    "erusev/parsedown": "1.6.0",
    "firebase/php-jwt": "3.0.0",
    "guzzlehttp/guzzle": "6.3.0",
    "symfony/mime": "4.3.0",
    "laminas/laminas-http": "2.14.0",
    "laminas/laminas-diactoros": "2.2.0",
    "yiisoft/yii2": "2.0.15",
    "cakephp/cakephp": "3.5.0",
    "zendframework/zend-diactoros": "1.8.0",
    "zendframework/zend-http": "2.8.0",
    "drupal/core": "8.5.0",
    "magento/framework": "100.1.0",
    "typo3/cms-core": "8.7.0",
    "silverstripe/framework": "3.6.0",
    "smarty/smarty": "3.1.31",
    "twig/twig": "1.19.0",
    "pocketmine/pocketmine-mp": "3.0.0",
    "php-amqplib/php-amqplib": "2.6.0",
    "amphp/http-client": "4.0.0",

    "_comment_abandoned": "--- Abandoned / unmaintained packages ---",
    "zendframework/zend-mvc": "3.1.0",
    "ircmaxell/password-compat": "1.0.4",
    "phpunit/dbunit": "2.0.0",
    "fzaninotto/faker": "1.4.*",
    "swiftmailer/swiftmailer": "5.2.0",
    "composer/package-versions-deprecated": "1.11.99",
    "sensio/framework-extra-bundle": "5.1.0"
  },

  "_comment_require_dev": "DEV DEPENDENCIES — vulnerable testing and development tools",
  "require-dev": {
    "phpunit/phpunit": "4.8.0",
    "mockery/mockery": "0.9.0",
    "squizlabs/php_codesniffer": "1.5.6",
    "phpspec/prophecy": "1.5.0",
    "phpstan/phpstan": "0.9.0",
    "friendsofphp/php-cs-fixer": "2.0.0",
    "behat/behat": "3.1.0",
    "codeception/codeception": "2.2.0",
    "filp/whoops": "1.1.0",
    "fzaninotto/faker": "1.4.0",
    "brianium/paratest": "1.0.0",
    "symfony/var-dumper": "2.7.0",
    "symfony/debug": "2.7.0",
    "phpunit/php-code-coverage": "2.0.0",
    "sebastian/comparator": "1.2.0"
  },

  "_comment_conflict": "CONFLICT — declare known incompatible packages",
  "conflict": {
    "symfony/symfony": "<2.7.0",
    "twig/twig": "<1.18.0"
  },

  "_comment_replace": "REPLACE — declare packages this project replaces",
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-mbstring": "*",
    "symfony/polyfill-php72": "*",
    "paragonie/random_compat": "9.99.99"
  },

  "_comment_provide": "PROVIDE — declare virtual package implementations",
  "provide": {
    "psr/log-implementation": "1.0.0",
    "psr/cache-implementation": "1.0.0",
    "psr/container-implementation": "1.0.0"
  },

  "suggest": {
    "ext-mcrypt": "Required for legacy encryption (deprecated in PHP 7.1)",
    "ext-mysql": "For MySQL database connections (removed in PHP 7.0)",
    "ext-gd": "Required for image processing",
    "ext-imagick": "Alternative image processing library",
    "ext-redis": "For Redis cache driver",
    "ext-memcached": "For Memcached cache driver"
  },

  "autoload": {
    "psr-4": {
      "VulnerableApp\\": "src/",
      "VulnerableApp\\Http\\": "src/Http/",
      "VulnerableApp\\Models\\": "src/Models/"
    },
    "psr-0": {
      "OldNamespace": "src/legacy/",
      "Legacy_Class_": "src/legacy/"
    },
    "classmap": [
      "database/",
      "legacy/",
      "src/Helpers/"
    ],
    "files": [
      "src/helpers.php",
      "src/constants.php"
    ],
    "exclude-from-classmap": [
      "/tests/",
      "/database/seeds/"
    ]
  },

  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Tests\\Unit\\": "tests/Unit/",
      "Tests\\Feature\\": "tests/Feature/"
    }
  },

  "repositories": [
    {
      "type": "composer",
      "url": "https://packagist.org"
    },
    {
      "_comment": "VCS repository — pulls directly from a Git repo",
      "type": "vcs",
      "url": "https://github.com/example/vulnerable-lib"
    },
    {
      "_comment": "Path repository — local package",
      "type": "path",
      "url": "../packages/local-lib",
      "options": {
        "symlink": true
      }
    },
    {
      "_comment": "Package repository — inline package definition",
      "type": "package",
      "package": {
        "name": "vendor/legacy-package",
        "version": "1.0.0",
        "dist": {
          "url": "https://example.com/legacy-package-1.0.0.zip",
          "type": "zip"
        },
        "autoload": {
          "classmap": [
            "."
          ]
        }
      }
    }
  ],

  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "phpstan/extension-installer": true
    },
    "platform": {
      "php": "5.6.30"
    },
    "process-timeout": 600,
    "discard-changes": true
  },

  "scripts": {
    "post-install-cmd": [
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan package:discover --ansi"
    ],
    "post-autoload-dump": [
      "@php artisan package:discover --ansi"
    ],
    "test": [
      "@php vendor/bin/phpunit"
    ],
    "lint": [
      "@php vendor/bin/phpcs --standard=PSR2 src/"
    ],
    "fix": [
      "@php vendor/bin/php-cs-fixer fix src/"
    ]
  },

  "scripts-descriptions": {
    "test": "Run the application tests",
    "lint": "Check code style with PHP_CodeSniffer",
    "fix": "Fix code style with PHP-CS-Fixer"
  },

  "extra": {
    "laravel": {
      "providers": [
        "VulnerableApp\\Providers\\AppServiceProvider"
      ],
      "aliases": {
        "App": "VulnerableApp\\Facades\\App"
      }
    },
    "branch-alias": {
      "dev-main": "1.0-dev"
    }
  },

  "bin": [
    "bin/console"
  ],

  "archive": {
    "exclude": [
      "/tests",
      "/docs",
      "/.github"
    ]
  },

  "non-feature-branches": [
    "legacy-.*"
  ]
}
